{
    "extends": "../../../tsconfig.build.json",

    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": ".",
        "module": "ES2020",
        "target": "es2021",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "declaration": true,
        "composite": true,
        "lib": ["es2021", "dom"]
    },

    "include": ["./src/**/*.ts", "./test/**/*.ts", "./scripts/**/*.ts"],
    "exclude": ["**/node_modules", "**/dist"]
}
